<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Game UI</title>
<style>
    body {
        background-color: #0d1117;
        color: white;
        font-family: Arial;
    }

    .btn {
        padding: 10px 15px;
        margin: 5px;
        background-color: #2f3337;
        border: none;
        color: white;
        cursor: pointer;
    }

    .btn:hover {
        background-color: #444;
    }

    .lane-container {
        margin-top: 10px;
        display: none; /* hidden muna */
    }

    .box {
        border: 1px solid #555;
        padding: 20px;
        margin-top: 15px;
    }
</style>
</head>
<body>

<!-- MAIN BUTTON -->
<button class="btn" onclick="toggleLane()">Mobile Legends</button>
<button class="btn">Honor of Kings</button>

<!-- LANE BUTTONS -->
<div id="lanes" class="lane-container">
    <button class="btn">EXP Lane</button>
    <button class="btn">Mid Lane</button>
    <button class="btn">Jungler</button>
    <button class="btn">Gold Lane</button>
    <button class="btn">Roam</button>
</div>

<!-- ERROR BOX -->
<div class="box">
    Error loading game: Game data not found
</div>

<script>
function toggleLane() {
    const lanes = document.getElementById("lanes");
    lanes.style.display = lanes.style.display === "none" ? "block" : "none";
}
</script>

</body>
</html>
